{
    "$schema": "https://raw.githubusercontent.com/revisit-studies/study/main/src/parser/StudyConfigSchema.json",
    "studyMetadata": {
        "title": "A3 Chart Visualization Study",
        "version": "pilot",
        "authors": [
            "CS573 Team Plot Twist"
        ],
        "date": "2026-03-05",
        "description": "A simple data visualization study",
        "organizations": [
            "WPI"
        ]
    },
    "uiConfig": {
        "contactEmail": "contact@revisit.dev",
        "helpTextPath": "a3-study/assets/help.md",
        "logoPath": "revisitAssets/revisitLogoSquare.svg",
        "withProgressBar": true,
        "autoDownloadStudy": false,
        "withSidebar": true
    },
    "baseComponents": {
        "bar-chart": {
            "type": "website",
            "response": [
                {
                    "id": "barChart",
                    "prompt": "Your selected answer:",
                    "required": true,
                    "location": "sidebar",
                    "type": "reactive"
                }
            ],
            "path": "a3-study/assets/bar-chart.html",
            "instructionLocation": "sidebar"
        }
    },  
    "components": {
        "introduction": {
            "type": "markdown",
            "path": "a3-study/assets/introduction.md",
            "response": []
        },
        "bar-1": {
            "type": "image",
            "path": "a3-study/assets/bar_gradientbysize.png",
            "instruction": "Estimate the percentage (0-100) the dotted bar is of the starred bar in the chart.",
            "style": {
                "width": "800px"
            },
            "nextButtonLocation": "sidebar",
            "response": [
                {
                    "id": "a3-study/assets-response",
                    "prompt": "Answer",
                    "location": "sidebar",
                    "type": "numerical",
                    "max": 100,
                    "min": 0
                }
            ]
        },
        "bar-2": {
            "type": "image",
            "path": "a3-study/assets/bar_gradientbylocation.png",
            "instruction": "Estimate the percentage (0-100) the dotted bar is of the starred bar in the chart.",
            "style": {
                "width": "800px"
            },
            "nextButtonLocation": "sidebar",
            "response": [
                {
                    "id": "a3-study/assets-response",
                    "prompt": "Answer",
                    "location": "sidebar",
                    "type": "numerical",
                    "max": 100,
                    "min": 0
                }
            ]

        },
        "bar-chart-1": {
            "baseComponent": "bar-chart",
            "description": "A trial for the user to click the largest bar",
            "instruction": "Click on the largest bar",
            "parameters": {
            "barData": [0.32, 0.01, 1.2, 1.3, 0.82, 0.4, 0.3]
            }
        },
        "bar-chart-2":{
            "baseComponent": "bar-chart",
            "description": "A trial for the user to click the smallest bar",
            "instruction": "Click on the smallest bar",
            "parameters": {
            "barData": [1.2, 1.2, 1.2, 1.3, 0.82, 0.4, 0.3]
            }
        }  
    }, 
    "sequence": {
        "order": "fixed",
        "components": [
            "introduction",
            "bar-1",
            "bar-2",
            "bar-chart-1",
            "bar-chart-2"
        ]
    }
}