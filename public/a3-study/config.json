{
    "$schema": "https://raw.githubusercontent.com/revisit-studies/study/main/src/parser/StudyConfigSchema.json",
    "studyMetadata": {
        "title": "A3 Chart Visualization Study",
        "version": "pilot",
        "authors": [
            "CS573 Team Plot Twist"
        ],
        "date": "2026-03-05",
        "description": "A simple data visualization study",
        "organizations": [
            "WPI"
        ]
    },
    "uiConfig": {
        "contactEmail": "contact@revisit.dev",
        "helpTextPath": "a3-study/assets/help.md",
        "logoPath": "revisitAssets/revisitLogoSquare.svg",
        "withProgressBar": true,
        "autoDownloadStudy": false,
        "withSidebar": true
    },
    "baseComponents": {
        "bar-chart": {
            "type": "website",
            "nextButtonLocation": "sidebar",
            "response": [
                {
                    "id": "barChart",
                    "prompt": "Enter the percentage (0-100) below:",
                    "required": true,
                    "location": "sidebar",
                    "type": "numerical",
                    "max": 100,
                    "min": 0
                }
            ],
            "path": "a3-study/assets/bar-charts.html",
            "instructionLocation": "sidebar"
        },
        "pie-chart": {
            "type": "website",
            "nextButtonLocation": "sidebar",
            "response": [
                {
                    "id": "pieChart",
                    "prompt": "Estimate the percentage (0-100) the dotted bar is of the starred bar:",
                    "required": true,
                    "location": "sidebar",
                    "type": "numerical",
                    "max": 100,
                    "min": 0
                }
            ],
            "path": "a3-study/assets/pie-chart.html",
            "instructionLocation": "sidebar"
        },
        "mosaic-chart": {
            "type": "website",
            "nextButtonLocation": "sidebar",
            "response": [
                {
                    "id": "mosaicChart",
                    "prompt": "Estimate the percentage (0-100) the dotted bar is of the starred bar:",
                    "required": true,
                    "location": "sidebar",
                    "type": "numerical",
                    "max": 100,
                    "min": 0
                }
            ],
            "path": "a3-study/assets/mosaicChart-chart.html",
            "instructionLocation": "sidebar"
        }
    },  
